{
  "mcpServers": {
    "google-analytics": {
      "command": "npx",
      "args": ["-y", "mcp-server-google-analytics"],
      "env": {
        "GOOGLE_CLIENT_EMAIL": "YOUR_SERVICE_ACCOUNT_EMAIL@YOUR_PROJECT.iam.gserviceaccount.com",
        "GOOGLE_PRIVATE_KEY": "YOUR_PRIVATE_KEY_FROM_JSON_FILE",
        "GA_PROPERTY_ID": "YOUR_NUMERIC_PROPERTY_ID"
      }
    }
  }
}
